# ============================================================
# Best Cars Dealership Platform — Environment Variables
# Copy this file to djangoapp/.env and fill in real values.
# NEVER commit the actual .env files with real secrets.
# ============================================================

# ── Django ───────────────────────────────────────────────────
# Django secret key — generate with: python -c "import secrets; print(secrets.token_hex(50))"
DJANGO_SECRET_KEY=your-super-secret-key-here-change-this

# Set to "production" when deploying — disables DEBUG, enables security settings
DJANGO_ENV=development

# Allowed hosts — comma-separated list, e.g. "localhost,yourdomain.com"
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── JWT Authentication ────────────────────────────────────────
# Access token lifetime in minutes (recommended: 15)
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15

# Refresh token lifetime in days (recommended: 7)
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Database ──────────────────────────────────────────────────
# Development: leave empty to use SQLite
# Production: set to postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# ── Redis ─────────────────────────────────────────────────────
# Redis URL for caching and event bus
# Docker: redis://redis:6379/0
# Local:  redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# Cache timeout for dealer list (in seconds, 300 = 5 minutes)
DEALER_CACHE_TIMEOUT=300

# ── Microservice URLs (inside Docker use container names) ──────
# When running via docker-compose, use the service names below.
# When running Django locally, use localhost URLs.

# Node.js Dealer & Review Service
backend_url=http://localhost:3030
# (Docker internal) DEALER_SERVICE_URL=http://database-api:3030

# Car Inventory Service
searchcars_url=http://localhost:3050/
# (Docker internal) INVENTORY_SERVICE_URL=http://carsinventory-api:3050

# Flask Sentiment Analyzer
sentiment_analyzer_url=http://localhost:5050/
# (Docker internal) SENTIMENT_SERVICE_URL=http://sentiment-analyzer:5050

# ── Circuit Breaker ────────────────────────────────────────────
# Seconds a circuit stays OPEN before trying HALF-OPEN
CIRCUIT_BREAKER_TIMEOUT=30

# Number of failures before circuit opens
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5

# ── Node.js Services ──────────────────────────────────────────
# Set to "development" or "production"
NODE_ENV=development

# MongoDB connection for dealer service
MONGO_DEALERS_URL=mongodb://localhost:27017/

# MongoDB connection for inventory service
MONGO_INVENTORY_URL=mongodb://localhost:27018/

# ── Flask Sentiment Analyzer ───────────────────────────────────
FLASK_ENV=development

# Directory where Hugging Face model is cached (first run downloads ~250MB)
MODEL_CACHE_DIR=./model_cache

# Set to "true" to force VADER-only mode (no transformer download)
USE_VADER_ONLY=false

# ── CORS ──────────────────────────────────────────────────────
# Origins allowed to call the Django API (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost

# ── Logging ───────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
